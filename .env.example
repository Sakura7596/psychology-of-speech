# DeepSeek API
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI API (备选)
OPENAI_API_KEY=your_api_key_here

# 运行环境: dev / test / prod / offline
APP_ENV=dev

# LLM 配置
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# 向量数据库
CHROMA_PERSIST_DIR=./data/embeddings

# 日志级别
LOG_LEVEL=INFO
